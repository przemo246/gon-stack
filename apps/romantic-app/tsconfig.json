{
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": [
    "dist",
    "test-results",
    "supabase",
    "./worker-configuration.d.ts"
  ],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "ESNext",
    "verbatimModuleSyntax": true,
    "types": ["./worker-configuration.d.ts", "node", "vitest/globals"],
    "strictNullChecks": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": ["./src/*"],
      "@schemas/*": ["./src/shared/server-contracts/schemas/*"]
    }
  }
}
