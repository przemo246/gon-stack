---
import Layout from '../layouts/Layout.astro';
import { supabaseServer } from '../shared/data-sources/supabase-server';

const supabase = supabaseServer({ request: Astro.request, cookies: Astro.cookies });
const { data: events, error } = await supabase.from('Events').select('*').order('start_date');
---

<Layout>
	<main>
		<h1>Events</h1>
		{error && <p class="error">Failed to load events: {error.message}</p>}
		{events && events.length === 0 && <p>No events found.</p>}
		{events && events.length > 0 && (
			<ul class="events-list">
				{events.map((event) => (
					<li class="event-card">
						{event.imageCover && <img src={event.imageCover} alt={event.name} />}
						<div class="event-info">
							<h2>{event.name}</h2>
							<p class="description">{event.description}</p>
							<p class="date">
								{new Date(event.start_date).toLocaleDateString()}
								{event.end_date && ` – ${new Date(event.end_date).toLocaleDateString()}`}
							</p>
						</div>
					</li>
				))}
			</ul>
		)}
	</main>
</Layout>

<style>
	main {
		max-width: 800px;
		margin: 2rem auto;
		padding: 0 1rem;
		font-family: sans-serif;
	}

	h1 {
		font-size: 2rem;
		margin-bottom: 1.5rem;
	}

	.error {
		color: red;
	}

	.events-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.event-card {
		border: 1px solid #ddd;
		border-radius: 8px;
		overflow: hidden;
		display: flex;
		gap: 1rem;
	}

	.event-card img {
		width: 160px;
		object-fit: cover;
	}

	.event-info {
		padding: 1rem;
	}

	.event-info h2 {
		margin: 0 0 0.5rem;
		font-size: 1.25rem;
	}

	.description {
		color: #555;
		margin: 0 0 0.5rem;
	}

	.date {
		font-size: 0.875rem;
		color: #888;
		margin: 0;
	}
</style>
